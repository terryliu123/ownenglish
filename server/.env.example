# =================== OwnEnglish 后端配置 ===================
# 复制此文件为 .env 并修改相应值

# 应用
APP_NAME=OwnEnglish
APP_VERSION=0.1.0
DEBUG=False
ENVIRONMENT=production

# 数据库（必改：改为你的 PostgreSQL 配置）
DATABASE_URL=postgresql+asyncpg://ownenglish:你的密码@127.0.0.1:5432/ownenglish

# JWT 密钥（必改：使用随机生成的强密钥，至少 32 字符）
SECRET_KEY=change-this-to-a-random-secret-key-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 允许域名（必改：改为你的生产域名）
ALLOWED_ORIGINS=https://mentex.cn,https://www.mentex.cn

# 上传文件基础目录（生产环境建议配置绝对路径）
UPLOADS_BASE_DIR=/www/wwwroot/ownenglish/server

# Redis（可选）
REDIS_URL=redis://localhost:6379

# AI 配置（可选）
SILICONFLOW_API_URL=https://api.siliconflow.com/v1/chat/completions
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=zai-org/GLM-5
SILICONFLOW_TIMEOUT_SECONDS=90

# 会员价格（单位：分）
MEMBERSHIP_MONTHLY_PRICE_CENTS=3900
MEMBERSHIP_YEARLY_PRICE_CENTS=39900

# SMTP 邮件配置（可选）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=OwnEnglish

# 前端 URL（用于邮件链接等）
FRONTEND_URL=https://mentex.cn

# 微信支付配置（可选）
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_MCH_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=
WECHAT_PAY_PLATFORM_PUBLIC_KEY=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_NOTIFY_URL=https://mentex.cn/api/v1/membership/notify
WECHAT_PAY_RETURN_URL=https://mentex.cn/membership/result
WECHAT_PAY_H5_DOMAIN=mentex.cn
